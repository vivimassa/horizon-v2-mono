MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/horizon?retryWrites=true&w=majority
JWT_SECRET=CHANGE_ME_must_be_at_least_32_characters_long_random_hex
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
PORT=3002
NODE_ENV=development
CORS_ORIGIN=*

# 4.1.6.1 Auto Roster CP-SAT solver service URL (separate from ML_API_URL)
AUTO_ROSTER_SOLVER_URL=http://localhost:8082
