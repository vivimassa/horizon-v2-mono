{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "description": "Block git commits that bypass hooks (--no-verify)",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$TOOL_INPUT\" | grep -q '\\-\\-no-verify' && echo '[BLOCKED] Do not bypass git hooks with --no-verify' >&2 && exit 2 || exit 0"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "description": "TypeScript type-check after file write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-typecheck.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "description": "Design system + architecture guard after file write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-guard.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "description": "TypeScript type-check after file edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-typecheck.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "description": "Design system + architecture guard after file edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-guard.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "description": "Generate session summary markdown on stop",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-summary.sh"
          }
        ]
      }
    ]
  }
}
