{
  "name": "server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "predev": "kill-port 3002 || exit 0",
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=8192 tsx watch --clear-screen=false --ignore=uploads --ignore=dist --ignore=**/*.log src/index.ts",
    "start:prod": "cross-env NODE_OPTIONS=--max-old-space-size=8192 node dist/index.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts --max-warnings 9999",
    "start": "node dist/index.js",
    "seed": "tsx src/seed.ts",
    "seed:user": "tsx src/seed-user.ts",
    "seed:crew-a320-cp": "tsx src/seed-crew-a320-cp.ts",
    "seed:crew-all-fleets": "tsx src/seed-crew-all-fleets.ts",
    "seed:crew-contacts": "tsx src/seed-crew-contacts.ts",
    "seed:crew-passports": "tsx src/seed-crew-passports.ts",
    "seed:crew-phones": "tsx src/seed-crew-phones.ts",
    "seed:crew-expiries": "tsx src/seed-crew-expiries.ts",
    "seed:crew-hotels": "tsx src/seed-crew-hotels.ts",
    "reseed:seniority": "tsx src/reseed-seniority.ts",
    "backfill:pairing-legality": "tsx src/backfill-pairing-legality.ts",
    "migrate": "tsx src/migrate-from-supabase.ts"
  },
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/cors": "^10.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^9.0.0",
    "@mongodb-js/zstd": "^2.0.1",
    "@skyhub/env": "*",
    "@supabase/supabase-js": "^2.101.0",
    "bcryptjs": "^3.0.3",
    "expo-server-sdk": "^3.10.0",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "fastify": "^5.2.0",
    "mongoose": "^8.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@skyhub/eslint-config": "*",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.0",
    "cross-env": "^7.0.3",
    "kill-port": "^2.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
