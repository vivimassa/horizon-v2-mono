{
  "name": "horizon-v2-mono",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n turbo,solver -c cyan,magenta \"npm:dev:turbo\" \"npm:dev:solver\"",
    "dev:turbo": "turbo dev",
    "predev:solver": "node scripts/free-solver-port.mjs",
    "dev:solver": "cd services/auto-roster-solver && python -m uvicorn app.main:app --host 0.0.0.0 --port 8082 --reload",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\" --ignore-path .gitignore",
    "prepare": "husky || true",
    "dev:server": "turbo dev --filter=server",
    "dev:web": "turbo dev --filter=web",
    "dev:mobile": "turbo dev --filter=@skyhub/mobile"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings 9999",
      "prettier --write"
    ],
    "*.{js,json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-only-warn": "^1.2.1",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.4.2",
    "turbo": "^2.5.0"
  },
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "react-native-svg": "15.12.1"
  }
}
